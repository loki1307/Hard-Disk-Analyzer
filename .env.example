# DiskSense AI — Environment Variables Template
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit the actual .env file to git.

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate-a-random-key-here

# ── Google OAuth ──────────────────────────────────────────────
# Setup: https://console.cloud.google.com → Credentials → OAuth 2.0
# Redirect URI: http://localhost:5000/auth/google/callback
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-YOUR_GOOGLE_CLIENT_SECRET

# ── GitHub OAuth ──────────────────────────────────────────────
# Setup: https://github.com/settings/developers → OAuth Apps
# Callback URL: http://localhost:5000/auth/github/callback
GITHUB_CLIENT_ID=YOUR_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=YOUR_GITHUB_CLIENT_SECRET

# ── App Config ────────────────────────────────────────────────
FLASK_ENV=development
DATABASE_URL=sqlite:///disksense.db
